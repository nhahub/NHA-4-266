# FastAPI inference backend base URL (no trailing slash).
# The app POSTs frames to `${VITE_API_URL}/predict` and pings `${VITE_API_URL}/health`.
#
# Local dev example:
#   VITE_API_URL=http://localhost:8000
#
# Production example (set this in Vercel > Project > Settings > Environment Variables):
#   VITE_API_URL=https://your-fastapi-backend.onrender.com
#
# Leave unset to run the frontend in standalone/simulation mode - the pipeline
# will display raw, unannotated frames instead of crashing. See
# src/services/apiService.js for the fallback logic.
VITE_API_URL=
